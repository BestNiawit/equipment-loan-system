{
  "name": "equipment-loan-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:logs:auth": "docker compose logs -f auth",
    "docker:logs:web": "docker compose logs -f web",
    "docker:reset": "docker compose down -v && docker compose up -d --build",
    "docker:rebuild": "docker compose build web && docker compose up -d web",
    "docker:setup": "bash scripts/setup-db.sh",
    "setup:local": "cp .env.local.docker .env.local && echo 'Done! Run: npm run docker:reset then npm run docker:setup'"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.48.1",
    "framer-motion": "^11.15.0",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^0.468.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.4",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "sonner": "^1.7.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
